{
  "name": "faaaahh-sound-extension",
  "displayName": "faaaahh Sound Extension",
  "description": "Plays a sound when a terminal error is detected.",
  "version": "0.0.2",
  "publisher": "Nik-doid",
  "repository": {
    "type": "git",
    "url": "https://github.com/Nik-doid/faaaahh-sound-extension.git"
  },
  "icon": "assets/logo.jpeg",
  "engines": {
    "vscode": "^1.56.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^16.18.0",
    "@types/vscode": "^1.56.0",
    "typescript": "^4.9.5"
  },
  "contributes": {
    "commands": [
      {
        "command": "faaaahh.showStatus",
        "title": "faaaahh: Show Status"
      },
      {
        "command": "faaaahh.testSound",
        "title": "faaaahh: Test Sound"
      },
      {
        "command": "faaaahh.toggle",
        "title": "faaaahh: Toggle Error Sounds On/Off"
      },
      {
        "command": "faaaahh.setCooldown",
        "title": "faaaahh: Set Cooldown Duration"
      },
      {
        "command": "faaaahh.addPattern",
        "title": "faaaahh: Add Custom Error Pattern"
      },
      {
        "command": "faaaahh.removePattern",
        "title": "faaaahh: Remove Error Pattern"
      },
      {
        "command": "faaaahh.listPatterns",
        "title": "faaaahh: List Active Error Patterns"
      },
      {
        "command": "faaaahh.resetPatterns",
        "title": "faaaahh: Reset Patterns to Default"
      }
    ],
    "configuration": {
      "title": "faaaahh",
      "properties": {
        "faaaahh.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable terminal error sound alerts."
        },
        "faaaahh.cooldownMs": {
          "type": "number",
          "default": 2000,
          "minimum": 500,
          "maximum": 30000,
          "description": "Minimum milliseconds between sounds to avoid spam."
        },
        "faaaahh.errorPatterns": {
          "type": "array",
          "items": { "type": "string" },
          "default": [
            "error",
            "failed",
            "fatal",
            "exception",
            "traceback",
            "npm err",
            "segmentation fault",
            "panic",
            "cannot find",
            "not found",
            "module not found"
          ],
          "description": "List of terminal output patterns that trigger the error sound."
        },
        "faaaahh.soundFile": {
          "type": "string",
          "default": "",
          "description": "Absolute path to a custom sound file (.mp3 or .wav). Leave empty to use the default."
        },
        "faaaahh.showStatusBarMessage": {
          "type": "boolean",
          "default": true,
          "description": "Show a status bar message when an error is detected."
        }
      }
    }
  }
}