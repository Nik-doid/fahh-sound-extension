{
  "name": "fahh-sound-extension",
  "displayName": "Fahh Sound Extension",
  "description": "Plays a sound when a terminal error is detected.",
  "version": "0.0.2",
  "publisher": "miunin",
  "engines": {
    "vscode": "^1.56.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^16.18.0",
    "@types/vscode": "^1.56.0",
    "typescript": "^4.9.5"
  },
  "contributes": {
    "commands": [
      {
        "command": "fahh.showStatus",
        "title": "Fahh: Show Status"
      },
      {
        "command": "fahh.testSound",
        "title": "Fahh: Test Sound"
      },
      {
        "command": "fahh.toggle",
        "title": "Fahh: Toggle Error Sounds On/Off"
      },
      {
        "command": "fahh.setCooldown",
        "title": "Fahh: Set Cooldown Duration"
      },
      {
        "command": "fahh.addPattern",
        "title": "Fahh: Add Custom Error Pattern"
      },
      {
        "command": "fahh.removePattern",
        "title": "Fahh: Remove Error Pattern"
      },
      {
        "command": "fahh.listPatterns",
        "title": "Fahh: List Active Error Patterns"
      },
      {
        "command": "fahh.resetPatterns",
        "title": "Fahh: Reset Patterns to Default"
      }
    ],
    "configuration": {
      "title": "Fahh",
      "properties": {
        "fahh.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable terminal error sound alerts."
        },
        "fahh.cooldownMs": {
          "type": "number",
          "default": 2000,
          "minimum": 500,
          "maximum": 30000,
          "description": "Minimum milliseconds between sounds to avoid spam."
        },
        "fahh.errorPatterns": {
          "type": "array",
          "items": { "type": "string" },
          "default": [
            "error",
            "failed",
            "fatal",
            "exception",
            "traceback",
            "npm err",
            "segmentation fault",
            "panic",
            "cannot find",
            "not found",
            "module not found"
          ],
          "description": "List of terminal output patterns that trigger the error sound."
        },
        "fahh.soundFile": {
          "type": "string",
          "default": "",
          "description": "Absolute path to a custom sound file (.mp3 or .wav). Leave empty to use the default."
        },
        "fahh.showStatusBarMessage": {
          "type": "boolean",
          "default": true,
          "description": "Show a status bar message when an error is detected."
        }
      }
    }
  }
}